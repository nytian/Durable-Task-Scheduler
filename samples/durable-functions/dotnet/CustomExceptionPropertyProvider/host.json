{
  "version": "2.0",
  "logging": {
    "logLevel": {
      "default": "Information",
      "DurableTask.Core": "Warning",
      "Microsoft.DurableTask": "Information",
      "Host.Triggers.DurableTask": "Information"
    }
  },
  "extensions": {
    "durableTask": {
      "hubName": "default",
      "storageProvider": {
        "type": "azureManaged",
        "connectionStringName": "DURABLE_TASK_SCHEDULER_CONNECTION_STRING"
      }
    }
  }
}
